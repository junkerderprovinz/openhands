{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    ":enableVulnerabilityAlertsWithLabel(security)"
  ],
  "timezone": "Europe/Vienna",
  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 6,
  "packageRules": [
    {
      "description": "Group all OpenHands image bumps into one PR with descriptive title",
      "matchPackageNames": ["docker.openhands.dev/openhands/openhands"],
      "groupName": "OpenHands",
      "commitMessageTopic": "OpenHands",
      "commitMessagePrefix": "feat:",
      "labels": ["upstream-bump"]
    },
    {
      "description": "Auto-merge minor + patch bumps of GitHub Actions (no risk for a template-only repo)",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "automergeType": "branch",
      "commitMessagePrefix": "ci:",
      "labels": ["github-actions"]
    },
    {
      "description": "Major GH Actions bumps stay as manual PRs",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "commitMessagePrefix": "ci:",
      "labels": ["github-actions", "major-update"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Pick up the OpenHands image tag from the Unraid template",
      "managerFilePatterns": ["/templates/openhands\\.xml$/"],
      "matchStrings": [
        "<Repository>(?<depName>docker\\.openhands\\.dev/openhands/openhands):(?<currentValue>[^<]+)</Repository>"
      ],
      "datasourceTemplate": "docker"
    }
  ]
}
